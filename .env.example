# --- Domain & URLs -----------------------------------------------------------
# Public domain Caddy will obtain a TLS certificate for.
# Local development: use "http://localhost" to disable HTTPS.
DOMAIN=links.example.com

# Base URL used to build short links returned by the API (no trailing slash).
BASE_URL=https://links.example.com

# --- Postgres ----------------------------------------------------------------
POSTGRES_USER=kurz
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=kurz

# --- Privacy -----------------------------------------------------------------
# Random salt for hashing visitor IPs (GDPR-friendly analytics).
# Generate one:  openssl rand -hex 16
HASH_SALT=change-me-random-hex

# --- Container image (used by docker compose & CI/CD) -------------------------
# GHCR image names must be lowercase, even if your GitHub username isn't.
IMAGE=ghcr.io/vladosier/kurz
TAG=latest
